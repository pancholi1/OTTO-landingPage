---
import '../styles/global.css';

// CTA endpoints — únicos destinos de acción en toda la página
const WA = "https://wa.me/5493329325672";
const WA_DEMO = "https://wa.me/5493329325672?text=Hola,%20soy%20director/a%20de%20una%20escuela%20y%20quiero%20agendar%20una%20demo%20de%20OTTO";
const WA_FAMILIAS = "https://wa.me/5493329325672?text=Hola,%20soy%20director/a%20y%20quiero%20ver%20c%C3%B3mo%20funciona%20OTTO%20en%20mi%20escuela";
const WA_DOCENTE = "https://wa.me/5493329325672?text=Hola,%20quiero%20ver%20la%20vista%20del%20docente%20de%20OTTO";
const WA_COMISION = "https://wa.me/5493329325672?text=Hola,%20quiero%20el%20material%20de%20OTTO%20para%20presentar%20a%20la%20comisi%C3%B3n%20directiva";
const MAIL = "mailto:contacto@ottoedu.com.ar";
// Abre el compositor de Gmail en una pestaña nueva (no depende del cliente de correo del SO)
const MAIL_GMAIL = "https://mail.google.com/mail/?view=cm&fs=1&to=contacto@ottoedu.com.ar&su=" +
  encodeURIComponent("Consulta sobre OTTO para mi escuela") +
  "&body=" +
  encodeURIComponent("Hola, soy director/a de una escuela y quiero saber más sobre OTTO.");
const LOGIN = "https://app.ottoedu.com.ar/login";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/pet.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>OTTO — Refuerzo escolar institucional para escuelas primarias · DGCyE</title>
    <meta name="description" content="Licencia institucional de refuerzo de lectoescritura y matemática para 1° a 3° grado, alineada al Diseño Curricular de la DGCyE. La docente elige y asigna en un clic; los chicos practican jugando. Para escuelas privadas de la Provincia de Buenos Aires." />
    <meta name="keywords" content="licencia institucional refuerzo escolar, plataforma educativa escuelas primarias Provincia de Buenos Aires, DGCyE primer ciclo, alternativa a clases particulares para colegios, panel docente tipo Classroom, lectoescritura primer ciclo" />
    <link rel="canonical" href="https://www.ottoedu.com.ar/" />
    <!-- Open Graph (WhatsApp, Facebook, LinkedIn) -->
    <meta property="og:title" content="OTTO — Refuerzo escolar institucional para escuelas primarias" />
    <meta property="og:description" content="Licencia institucional alineada al Diseño Curricular de la DGCyE. La docente elige y asigna en un clic; los chicos practican jugando. Provincia de Buenos Aires." />
    <meta property="og:image" content="https://ottoedu.com.ar/og-image.png" />
    <meta property="og:url" content="https://ottoedu.com.ar" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="OTTO — Refuerzo escolar institucional para escuelas primarias" />
    <meta name="twitter:description" content="Licencia institucional alineada al Diseño Curricular de la DGCyE. Para escuelas privadas de la Provincia de Buenos Aires." />
    <meta name="twitter:image" content="https://ottoedu.com.ar/og-image.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;0,14..32,900&display=swap" rel="stylesheet" />
    <style>
      /* Animaciones de entrada */
      .fade-up {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.55s cubic-bezier(0.16,1,0.3,1), transform 0.55s cubic-bezier(0.16,1,0.3,1);
      }
      .fade-up.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .fade-in {
        opacity: 0;
        transition: opacity 0.7s ease;
      }
      .fade-in.visible {
        opacity: 1;
      }
      .scale-in {
        opacity: 0;
        transform: scale(0.94);
        transition: opacity 0.55s cubic-bezier(0.16,1,0.3,1), transform 0.55s cubic-bezier(0.16,1,0.3,1);
      }
      .scale-in.visible {
        opacity: 1;
        transform: scale(1);
      }
      /* Delay helpers */
      .delay-1 { transition-delay: 0.08s; }
      .delay-2 { transition-delay: 0.16s; }
      .delay-3 { transition-delay: 0.24s; }
      .delay-4 { transition-delay: 0.32s; }
      .delay-5 { transition-delay: 0.40s; }

      /* Strike line */
      .strike-line {
        position: relative;
        display: inline-block;
      }
      .strike-line::after {
        content: '';
        position: absolute;
        top: 52%;
        left: 0;
        height: 3px;
        background: #EF4444;
        width: 0;
        transition: width 0.7s cubic-bezier(0.16,1,0.3,1) 0.5s;
        border-radius: 2px;
      }
      .strike-line.visible::after {
        width: 100%;
      }

      /* Float card */
      @keyframes floatCard {
        0%, 100% { transform: translateY(0px); }
        50%       { transform: translateY(-10px); }
      }
      .float-card {
        animation: floatCard 5s ease-in-out infinite;
      }

      /* Pulse dot */
      @keyframes pulseDot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.4; transform: scale(1.4); }
      }
      .pulse-dot {
        animation: pulseDot 2.2s ease-in-out infinite;
      }

      /* Bounce arrow */
      @keyframes bounceX {
        0%, 100% { transform: translateX(0); }
        50%       { transform: translateX(4px); }
      }
      .bounce-arrow { animation: bounceX 1.6s ease-in-out infinite; }

      /* Progress bar fill */
      @keyframes fillBar {
        from { width: 0; }
        to   { width: 80%; }
      }
      .progress-fill {
        animation: fillBar 1.4s cubic-bezier(0.16,1,0.3,1) 0.6s both;
      }

      /* Gradient mesh hero */
      .hero-bg {
        background-color: #f0f7ff;
        background-image:
          radial-gradient(ellipse 70% 60% at 90% 10%, rgba(3,105,161,0.12) 0%, transparent 70%),
          radial-gradient(ellipse 50% 50% at 5% 90%, rgba(140,44,230,0.09) 0%, transparent 60%),
          radial-gradient(ellipse 40% 40% at 50% 100%, rgba(16,185,129,0.05) 0%, transparent 70%);
      }

      /* Card glass effect */
      .glass-card {
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }

      /* Subtle grain for sections */
      .section-alt {
        background-color: #f8faff;
      }

      /* ===== Visual polish toolkit ===== */

      /* Decorative dot grid (hero + dark CTA backdrops) */
      .dot-grid {
        background-image: radial-gradient(rgba(3,105,161,0.13) 1px, transparent 1px);
        background-size: 22px 22px;
        -webkit-mask-image: radial-gradient(ellipse 60% 60% at 50% 40%, #000 30%, transparent 75%);
        mask-image: radial-gradient(ellipse 60% 60% at 50% 40%, #000 30%, transparent 75%);
      }
      .dot-grid-light {
        background-image: radial-gradient(rgba(255,255,255,0.14) 1px, transparent 1px);
        background-size: 24px 24px;
      }

      /* Gradient text (headlines / brand accents) */
      .text-gradient {
        background: linear-gradient(110deg, #0369A1 0%, #1E3A8A 45%, #8C2CE6 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
      }

      /* Animated shimmer sweep over a surface */
      @keyframes shimmer {
        0%   { transform: translateX(-150%) skewX(-12deg); }
        100% { transform: translateX(250%) skewX(-12deg); }
      }
      .shimmer { position: relative; overflow: hidden; }
      .shimmer::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.28), transparent);
        transform: translateX(-150%) skewX(-12deg);
        pointer-events: none;
      }
      .shimmer:hover::after { animation: shimmer 0.9s ease; }

      /* Soft glow ring used on the highlighted price / founder card */
      @keyframes glowPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(3,105,161,0.20), 0 18px 40px -18px rgba(3,105,161,0.45); }
        50%      { box-shadow: 0 0 0 6px rgba(3,105,161,0.07), 0 22px 48px -16px rgba(3,105,161,0.55); }
      }
      .glow-card { animation: glowPulse 3.6s ease-in-out infinite; }

      /* Gradient border wrapper (1px stroke that picks up brand hues) */
      .gradient-border {
        position: relative;
        background: #fff;
        border-radius: 1rem;
      }
      .gradient-border::before {
        content: '';
        position: absolute;
        inset: 0;
        padding: 1.5px;
        border-radius: inherit;
        background: linear-gradient(135deg, #0369A1, #8C2CE6 55%, #10B981);
        -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0.55;
        transition: opacity 0.3s ease;
        pointer-events: none;
      }
      .gradient-border:hover::before { opacity: 1; }

      /* Lift + spring on hover, smoother than translate alone */
      .lift {
        transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), box-shadow 0.35s cubic-bezier(0.16,1,0.3,1);
        will-change: transform;
      }
      .lift:hover {
        transform: translateY(-6px);
        box-shadow: 0 24px 48px -22px rgba(30,58,138,0.30);
      }

      /* Slow counter-floating blob (hero decoratives) */
      @keyframes floatBlob {
        0%, 100% { transform: translate(0,0) scale(1); }
        50%      { transform: translate(14px,-22px) scale(1.06); }
      }
      .float-blob { animation: floatBlob 16s ease-in-out infinite; }
      .float-blob-slow { animation: floatBlob 22s ease-in-out infinite reverse; }

      /* Gentle scale-breath for icons / mascots */
      @keyframes breathe {
        0%, 100% { transform: scale(1); }
        50%      { transform: scale(1.07); }
      }
      .breathe { animation: breathe 4s ease-in-out infinite; }

      /* Sheen across the primary CTA on hover */
      .btn-primary {
        position: relative;
        overflow: hidden;
        isolation: isolate;
      }
      .btn-primary::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(100deg, transparent 30%, rgba(255,255,255,0.35) 50%, transparent 70%);
        transform: translateX(-120%);
        transition: transform 0.6s cubic-bezier(0.16,1,0.3,1);
        z-index: -1;
      }
      .btn-primary:hover::before { transform: translateX(120%); }

      /* Section divider — soft wave/fade between bands */
      .fade-edge-top   { -webkit-mask-image: linear-gradient(to bottom, transparent, #000 40px); mask-image: linear-gradient(to bottom, transparent, #000 40px); }

      /* Reveal underline for eyebrows */
      .eyebrow-line::after {
        content: '';
        display: block;
        width: 28px;
        height: 3px;
        margin: 10px auto 0;
        border-radius: 2px;
        background: linear-gradient(90deg, #0369A1, #8C2CE6);
      }
      .eyebrow-line-left::after {
        content: '';
        display: block;
        width: 28px;
        height: 3px;
        margin: 10px 0 0;
        border-radius: 2px;
        background: linear-gradient(90deg, #8C2CE6, #0369A1);
      }

      /* FAQ accordion */
      .faq-item summary::-webkit-details-marker { display: none; }
      .faq-item summary { outline: none; }
      .faq-item[open] { box-shadow: 0 12px 30px -16px rgba(30,58,138,0.25); border-color: rgba(3,105,161,0.3); }
      .faq-item[open] > p { animation: faqReveal 0.35s ease; }
      @keyframes faqReveal {
        from { opacity: 0; transform: translateY(-4px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* Respect reduced-motion preferences */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.001ms !important;
        }
        .fade-up, .fade-in, .scale-in { opacity: 1 !important; transform: none !important; }
      }
    </style>
  </head>
  <body class="font-[Inter,system-ui,sans-serif] bg-white text-gray-900 antialiased overflow-x-hidden" style="font-feature-settings: 'kern' 1, 'liga' 1;">

    <!-- ===== NAVBAR ===== -->
    <header id="site-header" class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-transparent transition-all duration-300">
      <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group">
          <img src="/logoOtto.png" alt="OTTO" class="h-8 w-auto transition-transform duration-300 group-hover:scale-105" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
          <span class="hidden items-center gap-1">
            <span class="text-2xl font-extrabold text-gradient">otto</span>
          </span>
          <span class="text-[10px] text-gray-400 font-medium hidden sm:block tracking-wide border-l border-gray-200 pl-2.5">Para escuelas primarias · Provincia de Buenos Aires</span>
        </a>
        <div class="flex items-center gap-2">
          <a href={LOGIN}
            class="text-sm font-medium text-gray-600 hover:text-[#0369A1] transition-colors px-4 py-2 rounded-lg hover:bg-gray-50">
            Iniciar sesión
          </a>
          <a href={WA}
            class="btn-primary group flex items-center gap-1.5 px-4 py-2.5 bg-[#0369A1] text-white text-sm font-semibold rounded-xl shadow-sm hover:shadow-lg hover:shadow-[#0369A1]/25 hover:-translate-y-0.5 transition-all duration-300">
            Agendá una demo
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 bounce-arrow" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </nav>
    </header>

    <!-- ===== HERO — Mensaje principal: la sustitución del gasto familiar ===== -->
    <section class="hero-bg relative overflow-hidden pt-7 pb-10 md:pt-9 md:pb-12 lg:py-[clamp(2rem,4vh,3.5rem)]">
      <!-- Decorative elements -->
      <div class="absolute inset-0 dot-grid pointer-events-none"></div>
      <div class="float-blob absolute top-0 right-0 w-[620px] h-[620px] bg-[#0369A1]/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4 pointer-events-none"></div>
      <div class="float-blob-slow absolute bottom-0 left-0 w-96 h-96 bg-[#8C2CE6]/10 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4 pointer-events-none"></div>
      <div class="float-blob absolute top-1/3 left-1/2 w-72 h-72 bg-[#10B981]/8 rounded-full blur-3xl pointer-events-none"></div>

      <div class="relative max-w-6xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-8 lg:gap-12 items-center">
        <!-- Texto -->
        <div>
          <span class="fade-up inline-flex items-center gap-2 px-3.5 py-1.5 bg-white/90 backdrop-blur rounded-full border border-[#0369A1]/15 text-xs font-semibold text-[#1E3A8A] mb-5 shadow-sm shadow-[#0369A1]/5">
            <span class="pulse-dot w-2 h-2 rounded-full bg-[#10B981] inline-block flex-shrink-0"></span>
            Seleccionamos pocas escuelas por zona · Ciclo 2026
          </span>

          <h1 class="fade-up delay-1 text-[clamp(1.6rem,1.1rem+1.7vw,2.4rem)] font-extrabold text-gray-900 leading-[1.12] tracking-tight mb-2.5">
            Las familias de tu escuela ya pagan
            <span class="text-[#EF4444] strike-line" id="strike-target">$80.000–$150.000 por mes</span> en particulares.
          </h1>
          <h2 class="fade-up delay-2 text-[clamp(1.15rem,0.9rem+1vw,1.5rem)] font-extrabold leading-snug mb-3.5">
            <span class="text-gradient">OTTO lo trae adentro de la escuela</span>, por una fracción de lo que ya pagan.
          </h2>

          <p class="fade-up delay-3 text-sm sm:text-[15px] text-gray-500 leading-relaxed mb-4">
            Plataforma web de refuerzo de Matemática y Prácticas del Lenguaje para primer ciclo, <strong class="text-gray-800 font-semibold">alineada al Diseño Curricular de la DGCyE</strong>. Tus docentes eligen una actividad y la proyectan en el pizarrón o la asignan en un clic, los chicos practican jugando, y la escuela puede mostrarle a cada familia cómo avanza su hijo. Algo que ninguna otra escuela de tu zona ofrece todavía.
          </p>

          <!-- Stats -->
          <div class="fade-up delay-4 grid grid-cols-3 gap-2.5 mb-4">
            {[
              { v: "1° a 3°", l: "Refuerzo de primer ciclo" },
              { v: "9", l: "Tipos de actividad interactiva" },
              { v: "DGCyE", l: "Alineado al Diseño Curricular" },
            ].map(({ v, l }) => (
              <div class="rounded-2xl bg-white/70 backdrop-blur border border-white/80 shadow-sm px-3.5 py-2.5 lift">
                <p class="text-lg sm:text-xl font-extrabold text-gradient tracking-tight">{v}</p>
                <p class="text-[11px] text-gray-500 mt-0.5 leading-snug">{l}</p>
              </div>
            ))}
          </div>

          <div class="fade-up delay-5 flex flex-col sm:flex-row gap-3">
            <a href={WA_DEMO}
              class="btn-primary group flex items-center justify-center gap-2 px-6 py-3 bg-[#0369A1] text-white font-bold rounded-2xl shadow-lg shadow-[#0369A1]/25 hover:shadow-xl hover:shadow-[#0369A1]/30 hover:-translate-y-0.5 transition-all duration-300 text-[15px]">
              Agendá una demo
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href={MAIL_GMAIL} target="_blank" rel="noopener noreferrer"
              class="group flex items-center justify-center gap-2 px-6 py-3 border border-gray-300 bg-white/60 backdrop-blur text-gray-700 font-semibold rounded-2xl hover:bg-white hover:border-[#0369A1]/40 hover:text-[#0369A1] transition-all duration-300 text-[15px]">
              <svg class="w-4 h-4 text-gray-400 group-hover:text-[#0369A1] transition-colors" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
              </svg>
              Escribinos por mail
            </a>
          </div>
          <p class="fade-up delay-5 text-xs text-gray-400 mt-3">Sin prueba gratis · Cláusula de salida las primeras 3 semanas de agosto, sin cargo ni penalidad. La demo no compromete a nada.</p>
        </div>

        <!-- Card flotante mock-up — vista del docente / clase -->
        <div class="fade-in delay-3 flex justify-center">
          <div class="relative w-full max-w-sm">
            <!-- halo glow behind card -->
            <div class="absolute -inset-6 bg-gradient-to-tr from-[#0369A1]/20 via-[#8C2CE6]/15 to-[#10B981]/15 blur-2xl rounded-[2rem] pointer-events-none"></div>

            <div class="float-card glass-card relative rounded-3xl shadow-2xl shadow-[#1E3A8A]/15 ring-1 ring-white/60 p-6 w-full">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-11 h-11 rounded-xl bg-[#0369A1]/8 flex items-center justify-center overflow-hidden">
                  <img src="/pet.png" alt="OTTO, el búho mascota de la plataforma educativa" width="40" height="40" loading="eager" decoding="async" class="w-9 h-9 object-contain breathe" />
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-semibold text-gray-900 text-sm">Clase · 1° A</p>
                  <p class="text-xs text-gray-400 mt-0.5">Práctica: Lectura — La leyenda del ombú</p>
                </div>
                <span class="text-[11px] bg-emerald-50 text-emerald-600 font-semibold px-2.5 py-1 rounded-full border border-emerald-100 inline-flex items-center gap-1">
                  <span class="pulse-dot w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Lista
                </span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-2 mb-1.5 overflow-hidden">
                <div class="progress-fill bg-gradient-to-r from-[#0369A1] to-[#8C2CE6] h-2 rounded-full"></div>
              </div>
              <p class="text-[11px] text-gray-400 mb-5">Curso completado</p>
              <div class="grid grid-cols-2 gap-3 mb-5">
                <div class="bg-emerald-50 rounded-2xl p-3.5 flex items-center gap-2.5 border border-emerald-100/80 lift">
                  <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <p class="text-sm font-semibold text-gray-700">24 activos</p>
                </div>
                <div class="bg-blue-50 rounded-2xl p-3.5 flex items-center gap-2.5 border border-blue-100/80 lift">
                  <svg class="w-4 h-4 text-[#0369A1] flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  <p class="text-sm font-semibold text-gray-700">12 tareas</p>
                </div>
