---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/pet.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>OTTO — Refuerzo escolar online alineado al currículo de Buenos Aires</title>
    <meta name="description" content="¿Cansado de pagar clases particulares? OTTO es la plataforma de refuerzo escolar online para 1° a 3° grado, 100% alineada al Diseño Curricular de Buenos Aires. Actividades gamificadas, adaptativas y con seguimiento para padres." />
    <meta name="keywords" content="refuerzo escolar online primaria, clases particulares alternativa Buenos Aires, actividades educativas online niños, app educativa primaria Argentina, ejercicios matemática 2do grado, diseño curricular la Provian de Buenos Aires" />
    <link rel="canonical" href="https://www.ottoedu.com.ar/" />
    <!-- Open Graph (WhatsApp, Facebook, LinkedIn) -->
    <meta property="og:title" content="OTTO — Refuerzo escolar online para primaria" />
    <meta property="og:description" content="Actividades gamificadas alineadas al Diseño Curricular de Buenos Aires. Sin clases particulares, sin turnos." />
    <meta property="og:image" content="https://ottoedu.com.ar/og-image.png" />
    <meta property="og:url" content="https://ottoedu.com.ar" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="OTTO — Refuerzo escolar online para primaria" />
    <meta name="twitter:description" content="Actividades gamificadas alineadas al Diseño Curricular de Buenos Aires." />
    <meta name="twitter:image" content="https://ottoedu.com.ar/og-image.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;0,14..32,900&display=swap" rel="stylesheet" />
    <style>
      /* Animaciones de entrada */
      .fade-up {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.55s cubic-bezier(0.16,1,0.3,1), transform 0.55s cubic-bezier(0.16,1,0.3,1);
      }
      .fade-up.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .fade-in {
        opacity: 0;
        transition: opacity 0.7s ease;
      }
      .fade-in.visible {
        opacity: 1;
      }
      .scale-in {
        opacity: 0;
        transform: scale(0.94);
        transition: opacity 0.55s cubic-bezier(0.16,1,0.3,1), transform 0.55s cubic-bezier(0.16,1,0.3,1);
      }
      .scale-in.visible {
        opacity: 1;
        transform: scale(1);
      }
      /* Delay helpers */
      .delay-1 { transition-delay: 0.08s; }
      .delay-2 { transition-delay: 0.16s; }
      .delay-3 { transition-delay: 0.24s; }
      .delay-4 { transition-delay: 0.32s; }
      .delay-5 { transition-delay: 0.40s; }

      /* Strike line */
      .strike-line {
        position: relative;
        display: inline-block;
      }
      .strike-line::after {
        content: '';
        position: absolute;
        top: 52%;
        left: 0;
        height: 4px;
        background: #EF4444;
        width: 0;
        transition: width 0.7s cubic-bezier(0.16,1,0.3,1) 0.5s;
        border-radius: 2px;
      }
      .strike-line.visible::after {
        width: 100%;
      }

      /* Float card */
      @keyframes floatCard {
        0%, 100% { transform: translateY(0px); }
        50%       { transform: translateY(-10px); }
      }
      .float-card {
        animation: floatCard 5s ease-in-out infinite;
      }

      /* Pulse dot */
      @keyframes pulseDot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.4; transform: scale(1.4); }
      }
      .pulse-dot {
        animation: pulseDot 2.2s ease-in-out infinite;
      }

      /* Bounce arrow */
      @keyframes bounceX {
        0%, 100% { transform: translateX(0); }
        50%       { transform: translateX(4px); }
      }
      .bounce-arrow { animation: bounceX 1.6s ease-in-out infinite; }

      /* Progress bar fill */
      @keyframes fillBar {
        from { width: 0; }
        to   { width: 80%; }
      }
      .progress-fill {
        animation: fillBar 1.4s cubic-bezier(0.16,1,0.3,1) 0.6s both;
      }

      /* Gradient mesh hero */
      .hero-bg {
        background-color: #f0f7ff;
        background-image:
          radial-gradient(ellipse 70% 60% at 90% 10%, rgba(3,105,161,0.10) 0%, transparent 70%),
          radial-gradient(ellipse 50% 50% at 5% 90%, rgba(140,44,230,0.07) 0%, transparent 60%);
      }

      /* Card glass effect */
      .glass-card {
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }

      /* Subtle grain for sections */
      .section-alt {
        background-color: #f8faff;
      }
    </style>
  </head>
  <body class="font-[Inter,system-ui,sans-serif] bg-white text-gray-900 antialiased overflow-x-hidden" style="font-feature-settings: 'kern' 1, 'liga' 1;">

    <!-- ===== NAVBAR ===== -->
    <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100/80">
      <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/logoOtto.png" alt="OTTO" class="h-8 w-auto" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
          <span class="hidden items-center gap-1">
            <span class="text-2xl font-extrabold text-[#0369A1]">otto</span>
          </span>
          <span class="text-[10px] text-gray-400 font-medium hidden sm:block tracking-wide">Nivel Primario · Provincia de Buenos Aires</span>
        </a>
        <div class="flex items-center gap-2">
          <a href="https://app.ottoedu.com.ar/login"
            class="text-sm font-medium text-gray-600 hover:text-[#0369A1] transition-colors px-4 py-2 rounded-lg hover:bg-gray-50">
            Iniciar sesión
          </a>
          <a href="https://app.ottoedu.com.ar/register"
            class="flex items-center gap-1.5 px-4 py-2.5 bg-[#0369A1] text-white text-sm font-semibold rounded-xl hover:bg-[#1E3A8A] hover:shadow-md transition-all">
            Empezá gratis
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 bounce-arrow" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </nav>
    </header>

    <!-- ===== HERO — Mensaje principal: "Reemplazá el particular" ===== -->
    <section class="hero-bg relative overflow-hidden pt-10 pb-14">
      <!-- Decorative elements -->
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#0369A1]/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4 pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-[#8C2CE6]/5 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4 pointer-events-none"></div>

      <div class="relative max-w-6xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-10 items-center">
        <!-- Texto -->
        <div>
          <span class="fade-up inline-flex items-center gap-2 px-3.5 py-1.5 bg-white rounded-full border border-gray-200 text-xs font-semibold text-gray-600 mb-5 shadow-sm">
            <span class="pulse-dot w-2 h-2 rounded-full bg-[#10B981] inline-block flex-shrink-0"></span>
            Para niños de 1° a 3° grado
          </span>

          <h1 class="fade-up delay-1 text-3xl sm:text-4xl font-extrabold text-gray-900 leading-[1.1] tracking-tight mb-2">
            No gastes más en<br/>
            <span class="text-[#EF4444] strike-line" id="strike-target">clases particulares.</span>
          </h1>
          <h2 class="fade-up delay-2 text-2xl sm:text-3xl font-extrabold text-[#0369A1] leading-tight mb-5">
            Probá OTTO gratis.
          </h2>

          <p class="fade-up delay-3 text-base text-gray-500 leading-relaxed mb-6">
            El refuerzo escolar de tu hijo, <strong class="text-gray-800 font-semibold">alineado exactamente a lo que aprende en su escuela de Buenos Aires</strong>. Actividades gamificadas, adaptativas y con seguimiento para padres. Sin turnos, sin traslados, disponible las 24 hs.
          </p>

          <!-- Stats -->
          <div class="fade-up delay-4 flex gap-8 mb-6">
            <div>
              <p class="text-2xl font-extrabold text-[#1E3A8A] tracking-tight">4</p>
              <p class="text-xs text-gray-400 mt-0.5">Materias del<br/>currículum</p>
            </div>
            <div class="w-px bg-gray-200"></div>
            <div>
              <p class="text-2xl font-extrabold text-[#1E3A8A] tracking-tight">9</p>
              <p class="text-xs text-gray-400 mt-0.5">Tipos de<br/>actividades</p>
            </div>
            <div class="w-px bg-gray-200"></div>
            <div>
              <p class="text-2xl font-extrabold text-[#1E3A8A] tracking-tight">100%</p>
              <p class="text-xs text-gray-400 mt-0.5">Alineación<br/>curricular</p>
            </div>
          </div>

          <div class="fade-up delay-5 flex flex-col sm:flex-row gap-3">
            <a href="https://app.ottoedu.com.ar/register"
              class="flex items-center justify-center gap-2 px-7 py-3.5 bg-[#0369A1] text-white font-bold rounded-xl hover:bg-[#1E3A8A] hover:shadow-lg transition-all text-base">
              Empezá gratis hoy
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href="https://app.ottoedu.com.ar/login"
              class="flex items-center justify-center px-7 py-3.5 border border-gray-300 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 hover:border-gray-400 transition-all text-base">
              Iniciar sesión
            </a>
          </div>
          <p class="fade-up delay-5 text-xs text-gray-400 mt-3">Sin tarjeta de crédito · Cancelás cuando querés.</p>
        </div>

        <!-- Card flotante mock-up -->
        <div class="fade-in delay-3 flex justify-center">
          <div class="float-card glass-card rounded-2xl shadow-xl ring-1 ring-black/5 p-6 w-full max-w-sm">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 flex items-center justify-center overflow-hidden">
                <img src="/pet.png" alt="OTTO, el búho mascota de la plataforma de refuerzo escolar" width="40" height="40" loading="eager" decoding="async" class="w-full h-full object-contain" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-900 text-sm">Matemática · 2° Grado</p>
                <p class="text-xs text-gray-400 mt-0.5">Actividad: Contar elementos</p>
              </div>
              <span class="text-xs bg-emerald-50 text-emerald-600 font-semibold px-2.5 py-1 rounded-full border border-emerald-100">En progreso</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1.5 mb-5">
              <div class="progress-fill bg-[#0369A1] h-1.5 rounded-full"></div>
            </div>
            <div class="grid grid-cols-2 gap-3 mb-5">
              <div class="bg-emerald-50 rounded-xl p-3.5 flex items-center gap-2.5 border border-emerald-100/80">
                <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <p class="text-sm font-semibold text-gray-700">8 de 10 ok</p>
              </div>
              <div class="bg-blue-50 rounded-xl p-3.5 flex items-center gap-2.5 border border-blue-100/80">
                <svg class="w-4 h-4 text-[#0369A1] flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <p class="text-sm font-semibold text-gray-700">+50 pts</p>
              </div>
            </div>
            <div class="rounded-xl bg-gray-50 border border-gray-100 px-4 py-3 flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-[#0369A1] flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/></svg>
              <span class="text-xs text-gray-500">Para padres: <span class="font-semibold text-[#0369A1]">Sofía completó 3 actividades hoy</span></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== TRUST BAR ===== -->
    <div class="bg-[#1E3A8A] py-5">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
          {[
            "Contenido de Buenos Aires",
            "Seguro para menores",
            "Sin publicidad",
            "Cancelás cuando querés",
          ].map((label) => (
            <div class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4 text-emerald-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <p class="text-sm text-white font-medium">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ===== COMPARATIVA vs PARTICULAR ===== -->
    <section class="py-16 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-10">
          <span class="fade-up inline-block px-3.5 py-1 bg-red-50 text-red-500 text-xs font-semibold rounded-full mb-4 tracking-wide uppercase">
            El ahorro es real
          </span>
          <h2 class="fade-up text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight mb-3">
            OTTO vs. Clases particulares
          </h2>
          <p class="fade-up text-gray-500 text-base max-w-2xl mx-auto leading-relaxed">
            Los padres argentinos pagan entre $15.000 y $40.000 por mes en clases particulares. OTTO ofrece lo mismo —y más— en formato digital, gamificado y alineado al currículo real de tu hijo.
          </p>
        </div>

        <div class="fade-up grid md:grid-cols-2 gap-5 max-w-3xl mx-auto">
          <!-- Clases particulares -->
          <div class="rounded-2xl border border-gray-200 p-7 bg-gray-50/50">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-9 h-9 rounded-xl bg-gray-200 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gray-500" viewBox="0 0 20 20" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <h3 class="font-bold text-gray-600 text-base">Clases particulares</h3>
            </div>
            <ul class="space-y-3.5">
              {[
                "$15.000–$40.000 por mes",
                "Traslados y horarios fijos",
                "Contenido genérico, no tu currículo",
                "Sin seguimiento digital",
                "Solo 2–3 veces por semana",
                "Puede ser aburrido para los chicos",
              ].map(t => (
                <li class="flex items-center gap-3 text-sm text-gray-500">
                  <svg class="w-4 h-4 text-red-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                  {t}
                </li>
              ))}
            </ul>
          </div>

          <!-- OTTO -->
          <div class="rounded-2xl border-2 border-[#0369A1] p-7 relative shadow-lg bg-white">
            <div class="absolute -top-3.5 right-5 bg-[#0369A1] text-white text-[10px] font-bold px-3 py-1 rounded-full tracking-widest uppercase">
              Recomendado
            </div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-9 h-9 rounded-xl bg-[#0369A1]/10 flex items-center justify-center flex-shrink-0 text-lg">🦉</div>
              <h3 class="font-bold text-[#0369A1] text-base">OTTO</h3>
            </div>
            <ul class="space-y-3.5">
              {[
                "Suscripción accesible",
                "Desde casa, cuando quieran",
                "100% alineado al aula de tu hijo",
                "Reportes de progreso para padres",
                "Gamificado: niveles, puntos e insignias",
                "Disponible las 24 hs, todos los días",
              ].map(t => (
                <li class="flex items-center gap-3 text-sm text-gray-700">
                  <svg class="w-4 h-4 text-[#10B981] flex-shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {t}
                </li>
              ))}
            </ul>
            <a href="https://app.ottoedu.com.ar/register"
              class="mt-7 w-full flex items-center justify-center gap-2 py-3 bg-[#0369A1] text-white font-bold rounded-xl hover:bg-[#1E3A8A] hover:shadow-md transition-all text-sm">
              Empezá gratis
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== DIFERENCIAL: El currículo como moat ===== -->
    <section class="py-16 section-alt">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-10">
          <span class="fade-up inline-block px-3.5 py-1 bg-[#0369A1]/8 text-[#0369A1] text-xs font-semibold rounded-full mb-4 tracking-wide uppercase">
            Nuestra mayor ventaja
          </span>
          <h2 class="fade-up text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight mb-3">
            El refuerzo que ninguna app global puede dar
          </h2>
          <p class="fade-up text-gray-500 text-base max-w-2xl mx-auto leading-relaxed">
            Khan Academy, Duolingo y otras plataformas usan contenido genérico americano. OTTO es la única plataforma alineada al <strong class="text-[#1E3A8A] font-semibold">Diseño Curricular oficial de la Provincia de Buenos Aires</strong>.
          </p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {[
            { icon: "📐", title: "Matemática", badge: "1° a 3° grado", desc: "Números, sumas, restas, geometría y resolución de problemas según lo que enseña la maestra." },
            { icon: "📖", title: "Prácticas del Lenguaje", badge: "1° a 3° grado", desc: "Lectura, escritura, comprensión textual y vocabulario alineado al DC de Buenos Aires." },
            { icon: "🔬", title: "Ciencias Naturales", badge: "1° a 3° grado", desc: "Los seres vivos, el cuerpo, el ambiente y más, tal como aparece en los cuadernos." },
            { icon: "🌎", title: "Ciencias Sociales", badge: "1° a 3° grado", desc: "La familia, el barrio, el tiempo histórico y la vida en comunidad según el currículum." },
          ].map(({ icon, title, badge, desc }, i) => (
            <div class={`fade-up delay-${i + 1} bg-white rounded-2xl border border-gray-100 hover:border-[#0369A1]/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-200 p-6`}>
              <div class="w-12 h-12 bg-[#0369A1]/8 rounded-xl flex items-center justify-center text-xl mb-5">{icon}</div>
              <span class="text-[10px] font-bold uppercase tracking-widest text-[#8C2CE6]">{badge}</span>
              <h3 class="font-bold text-gray-900 mt-2 mb-2 text-[15px]">{title}</h3>
              <p class="text-sm text-gray-500 leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== PARA PADRES OCUPADOS ===== -->
    <section class="py-16 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 grid md:grid-cols-2 gap-10 items-center">
        <div>
          <span class="fade-up inline-block px-3.5 py-1 bg-purple-50 text-[#8C2CE6] text-xs font-semibold rounded-full mb-4 tracking-wide uppercase">
            Para padres que quieren lo mejor
          </span>
          <h2 class="fade-up text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight mb-4">
